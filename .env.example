DATABASE_URL=
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://investors.aromaria.io
RESEND_API_KEY=
EMAIL_FROM=portal@investors.aromaria.io
# File uploads land on a Railway persistent volume. Mount the volume in
# the Railway dashboard at /data and set this to /data/uploads. Locally
# this can be omitted, in which case files go in ./.uploads.
UPLOAD_DIR=/data/uploads
# AI document diffing (Claude via Anthropic API). Without ANTHROPIC_API_KEY
# new-version uploads still work, but the "what changed" summary is skipped.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# Hard cap on AI diffs per 24h. Beyond this, new-version uploads still
# happen but the AI summary is marked skipped_quota.
AI_DIFF_DAILY_CAP=200
NEXT_PUBLIC_CALCULATOR_URL=
NODE_ENV=production
