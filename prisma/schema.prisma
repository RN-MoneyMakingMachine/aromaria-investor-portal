generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Side {
  NIKAIDO
  OMOY
  AROMARIA_TEAM
  AUDITOR
}

enum Role {
  ADMIN
  EDITOR
  VIEWER
  INVESTOR
}

enum Phase {
  WIRE_CONDITION
  COMMITTED
  POST_SIGNING
  COMPLETED_PRE_60D
}

enum Category {
  GOVERNANCE
  REPORTING
  LEGAL
  BUSINESS
  STRUCTURE
  HR
  FINANCIAL
  RISK
  FUNDING
}

enum Status {
  NOT_STARTED
  IN_PROGRESS
  BLOCKED
  SUBMITTED_FOR_REVIEW
  IN_REVIEW
  COMPLETED
}

enum Priority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum ReportType {
  FINANCIAL
  GROWTH
  CREATIVE
  SPECIAL_PROJECT
  WEEKLY_BANK_STATEMENT
  MONTHLY_OPERATING
  QUARTERLY_BOARD
  QUARTERLY_INVESTOR
  ANNUAL_AUDITED
  ANNUAL_OPERATING_PLAN
  MATERIAL_EVENT_DISCLOSURE
  UPSIDE_NOTICE
}

enum ReportStatus {
  DRAFT
  DELIVERED
  ACKNOWLEDGED
  ACTION_REQUIRED
}

enum InformationRequestStatus {
  SUBMITTED
  ACKNOWLEDGED
  IN_PROGRESS
  DELIVERED
  DECLINED
}

enum DecisionStatus {
  OPEN
  APPROVED
  DECLINED
  IMPLEMENTED
}

enum DecisionZone {
  ZONE_1
  ZONE_2
  ZONE_3
  ZONE_4
  EMERGENCY
  THRESHOLD
}

enum DecisionTier {
  TIER_1
  TIER_2
}

enum MeetingType {
  REGULAR
  QUARTERLY
  SPECIAL
  EMERGENCY
}

enum MeetingStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  MINUTES_APPROVED
}

enum AgendaItemType {
  INFORMATION
  DISCUSSION
  DECISION
  RESERVED_MATTER
}

enum RsvpStatus {
  PENDING
  CONFIRMED
  DECLINED
  PROXY
}

enum ResolutionThresholdType {
  STANDARD
  TIER_1
  TIER_2
  FAMILY_ONLY
}

enum ResolutionOutcome {
  PENDING
  PASSED
  FAILED
  WITHDRAWN
}

enum VoteChoice {
  FOR
  AGAINST
  ABSTAIN
}

enum BankAccount {
  AROMARIA_LLC
  AROMARIA_UK_LTD
  AROMAS_Y_AMBIENTES
}

model User {
  id                     String          @id @default(cuid())
  email                  String          @unique
  name                   String
  title                  String?
  side                   Side
  role                   Role
  canApprove             Boolean         @default(false)
  emailVerified          DateTime?
  image                  String?
  createdAt              DateTime        @default(now())
  accounts               Account[]
  sessions               Session[]
  approvals              Approval[]
  comments               Comment[]
  statusChanges          StatusChange[]
  uploads                FileUpload[]
  auditEvents            AuditLog[]
  decisions              Decision[]      @relation("DecisionsCreated")
  bankStatementsUploaded BankStatement[] @relation("BankStatementUploads")
  bankStatementsReviewed BankStatement[] @relation("BankStatementReviews")
  adoptionStepCompletions   AdoptionStepCompletion[] @relation("AdoptionStepCompletions")
  reportsAcknowledged       Report[]              @relation("ReportAcknowledged")
  informationRequestsAuthor InformationRequest[]  @relation("InformationRequestAuthor")
  decisionsOwned            Decision[]            @relation("DecisionsOwned")
  retrospectivesRecorded    DecisionRetrospective[] @relation("RetrospectivesRecorded")
  meetingAttendances        MeetingAttendance[]   @relation("MeetingAttendances")
  boardVotes                BoardVote[]           @relation("BoardVotes")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Deliverable {
  id                     String         @id @default(cuid())
  code                   String         @unique
  name                   String
  description            String         @db.Text
  phase                  Phase
  category               Category
  sectionRef             String
  priority               Priority
  implementationTimeline String?
  status                 Status         @default(NOT_STARTED)
  progressPercent        Int            @default(0)
  targetDate             DateTime?
  ownerId                String?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  approvals              Approval[]
  comments               Comment[]
  files                  FileUpload[]
  statusChanges          StatusChange[]
  auditEvents            AuditLog[]
  adoptionStepCompletions AdoptionStepCompletion[]
}

model AdoptionStepCompletion {
  id            String      @id @default(cuid())
  deliverableId String
  stepIndex     Int
  completedById String
  completedAt   DateTime    @default(now())
  deliverable   Deliverable @relation(fields: [deliverableId], references: [id], onDelete: Cascade)
  completedBy   User        @relation("AdoptionStepCompletions", fields: [completedById], references: [id])

  @@unique([deliverableId, stepIndex])
  @@index([deliverableId])
}

model Approval {
  id            String      @id @default(cuid())
  deliverableId String
  userId        String
  side          Side
  approvedAt    DateTime    @default(now())
  deliverable   Deliverable @relation(fields: [deliverableId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id])

  @@unique([deliverableId, side])
}

model Comment {
  id            String      @id @default(cuid())
  deliverableId String
  userId        String
  body          String      @db.Text
  parentId      String?
  createdAt     DateTime    @default(now())
  deliverable   Deliverable @relation(fields: [deliverableId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id])
  parent        Comment?    @relation("Replies", fields: [parentId], references: [id])
  replies       Comment[]   @relation("Replies")
}

model FileUpload {
  id                String         @id @default(cuid())
  deliverableId     String?
  reportId          String?
  meetingId         String?
  userId            String
  filename          String
  url               String
  mimeType          String
  sizeBytes         Int
  version           Int            @default(1)
  isCurrent         Boolean        @default(true)
  isFinal           Boolean        @default(false)
  previousVersionId String?
  aiDiffStatus      String?
  aiDiffSummary     String?        @db.Text
  aiDiffError       String?        @db.Text
  aiDiffModel       String?
  aiDiffTokensIn    Int?
  aiDiffTokensOut   Int?
  uploadedAt        DateTime       @default(now())
  deliverable       Deliverable?   @relation(fields: [deliverableId], references: [id])
  report            Report?        @relation(fields: [reportId], references: [id])
  meeting           BoardMeeting?  @relation(fields: [meetingId], references: [id])
  user              User           @relation(fields: [userId], references: [id])
  previousVersion   FileUpload?    @relation("VersionChain", fields: [previousVersionId], references: [id], onDelete: SetNull)
  nextVersions      FileUpload[]   @relation("VersionChain")
  bankStatement     BankStatement?

  @@index([previousVersionId])
  @@index([deliverableId, isCurrent])
}

model BankStatement {
  id           String      @id @default(cuid())
  account      BankAccount
  weekOf       DateTime    @db.Date
  fileId       String      @unique
  file         FileUpload  @relation(fields: [fileId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy   User        @relation("BankStatementUploads", fields: [uploadedById], references: [id])
  uploadedAt   DateTime    @default(now())
  reviewedAt   DateTime?
  reviewedById String?
  reviewedBy   User?       @relation("BankStatementReviews", fields: [reviewedById], references: [id])

  @@index([account, weekOf])
  @@index([reviewedAt])
}

model StatusChange {
  id            String      @id @default(cuid())
  deliverableId String
  userId        String
  fromStatus    Status
  toStatus      Status
  changedAt     DateTime    @default(now())
  deliverable   Deliverable @relation(fields: [deliverableId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id])
}

model BoardMeeting {
  id           String        @id @default(cuid())
  title        String
  meetingDate  DateTime
  startsAt     DateTime?
  durationMin  Int?
  location     String?
  type         MeetingType   @default(REGULAR)
  status       MeetingStatus @default(SCHEDULED)
  agenda       String?       @db.Text
  minutes      String?       @db.Text
  decisions    String?       @db.Text
  attendees    String[]
  createdAt    DateTime      @default(now())
  startedAt    DateTime?
  endedAt      DateTime?
  files        FileUpload[]
  agendaItems  AgendaItem[]
  rsvps        MeetingAttendance[]
  resolutions  BoardResolution[]
}

model AgendaItem {
  id            String          @id @default(cuid())
  meetingId     String
  meeting       BoardMeeting    @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  title         String
  body          String?         @db.Text
  leadPresenter String?
  timeMinutes   Int?
  itemType      AgendaItemType  @default(DISCUSSION)
  order         Int             @default(0)
  createdAt     DateTime        @default(now())

  @@index([meetingId, order])
}

model MeetingAttendance {
  id          String       @id @default(cuid())
  meetingId   String
  meeting     BoardMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  userId      String
  user        User         @relation("MeetingAttendances", fields: [userId], references: [id])
  rsvpStatus  RsvpStatus   @default(PENDING)
  rsvpNote    String?
  rsvpAt      DateTime?
  attendedAt  DateTime?
  proxyForId  String?
  updatedAt   DateTime     @updatedAt

  @@unique([meetingId, userId])
  @@index([userId])
}

model BoardResolution {
  id            String                  @id @default(cuid())
  meetingId     String
  meeting       BoardMeeting            @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  title         String
  body          String                  @db.Text
  thresholdType ResolutionThresholdType @default(STANDARD)
  outcome       ResolutionOutcome       @default(PENDING)
  resolvedAt    DateTime?
  lockedAt      DateTime?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  votes         BoardVote[]

  @@index([meetingId])
}

model BoardVote {
  id           String          @id @default(cuid())
  resolutionId String
  resolution   BoardResolution @relation(fields: [resolutionId], references: [id], onDelete: Cascade)
  userId       String
  user         User            @relation("BoardVotes", fields: [userId], references: [id])
  choice       VoteChoice
  comment      String?
  castAt       DateTime        @default(now())

  @@unique([resolutionId, userId])
  @@index([userId])
}

model Report {
  id          String       @id @default(cuid())
  title       String
  type        ReportType
  periodLabel String
  summary     String?      @db.Text
  publishedAt DateTime     @default(now())
  dueDate     DateTime?
  status      ReportStatus @default(DELIVERED)
  actionLabel String?
  acknowledgedAt   DateTime?
  acknowledgedById String?
  acknowledgedBy   User?    @relation("ReportAcknowledged", fields: [acknowledgedById], references: [id])
  files       FileUpload[]

  @@index([type, dueDate])
  @@index([status])
}

model InformationRequest {
  id              String                   @id @default(cuid())
  subject         String
  body            String                   @db.Text
  authorId        String
  author          User                     @relation("InformationRequestAuthor", fields: [authorId], references: [id])
  isSubstantive   Boolean                  @default(true)
  status          InformationRequestStatus @default(SUBMITTED)
  acknowledgedAt  DateTime?
  deliveredAt     DateTime?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  @@index([status])
  @@index([createdAt])
}

model Decision {
  id                   String         @id @default(cuid())
  title                String
  summary              String         @db.Text
  body                 String?        @db.Text
  status               DecisionStatus @default(OPEN)
  zone                 DecisionZone?
  tier                 DecisionTier?
  ownerId              String?
  targetCompletionDate DateTime?
  decidedAt            DateTime?
  createdById          String
  createdBy            User           @relation("DecisionsCreated", fields: [createdById], references: [id])
  owner                User?          @relation("DecisionsOwned", fields: [ownerId], references: [id])
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  prerequisites        DecisionDependency[] @relation("Dependent")
  dependents           DecisionDependency[] @relation("Prerequisite")
  retrospectives       DecisionRetrospective[]

  @@index([status])
  @@index([zone])
  @@index([createdAt])
}

model DecisionDependency {
  id             String   @id @default(cuid())
  dependentId    String
  prerequisiteId String
  createdAt      DateTime @default(now())
  dependent      Decision @relation("Dependent",     fields: [dependentId],    references: [id], onDelete: Cascade)
  prerequisite   Decision @relation("Prerequisite",  fields: [prerequisiteId], references: [id], onDelete: Cascade)

  @@unique([dependentId, prerequisiteId])
  @@index([prerequisiteId])
}

model DecisionRetrospective {
  id            String   @id @default(cuid())
  decisionId    String
  dayMark       Int
  content       String   @db.Text
  recordedById  String
  recordedAt    DateTime @default(now())
  decision      Decision @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  recordedBy    User     @relation("RetrospectivesRecorded", fields: [recordedById], references: [id])

  @@unique([decisionId, dayMark])
  @@index([decisionId])
}

model AuditLog {
  id            String       @id @default(cuid())
  userId        String?
  deliverableId String?
  action        String
  entityType    String
  entityId      String?
  metadata      Json?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime     @default(now())
  user          User?        @relation(fields: [userId], references: [id])
  deliverable   Deliverable? @relation(fields: [deliverableId], references: [id])

  @@index([createdAt])
  @@index([userId])
  @@index([entityType, entityId])
}
